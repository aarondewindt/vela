{
  "editor.rulers": [ 80, 100, 120 ],  
  "editor.tabSize": 2,
  "editor.insertSpaces": true,

  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.profiles.linux": {
      "zsh": {
          "path": "/bin/zsh"
      }
  },

  "cssVariables.lookupFiles": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.less",
    "node_modules/@mantine/core/styles.css"
  ]
  
}