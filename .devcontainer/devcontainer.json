// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Vela Dev Container",
	"dockerComposeFile": "docker-compose.yml",
	"service": "dev",
	"workspaceFolder": "/workspaces/vela",
	"shutdownAction": "stopCompose",
	"postCreateCommand": "yarn install",
	"postStartCommand": "docker compose -f .devcontainer/docker-compose.inner.yml up -d",
	"forwardPorts": [3000, 5050],
	"customizations": {
		"vscode": {
			"extensions": []
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:4.0.0": {
			"dockerDashComposeVersion": "none"
		}
	}
}
